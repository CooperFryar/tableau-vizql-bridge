# tableau-vizql-bridge - environment configuration
# Copy to `.env` and fill in. `.env` is gitignored; never commit real credentials.

# --- Tableau Cloud login (used by the persistent browser session) ---
# Your pod's sign-in URL, e.g. https://10ay.online.tableau.com
TABLEAU_CLOUD_URL=https://<pod>.online.tableau.com

# Recommended: leave the two below blank and just log in once in the browser
# window the session opens. The login is saved (tableau_cloud_state/auth.json)
# and reused, so no password is stored on disk.
# Optional auto-login (stores a plaintext password): set both to sign in headlessly.
TABLEAU_EMAIL=
TABLEAU_PASSWORD=

# --- Browser / CDP bridge (usually leave as default) ---
# The persistent session exposes Chrome DevTools Protocol here; scripts connect over it.
TABLEAU_CDP_URL=http://localhost:9222
